{
  "name": "engler-gmbh-website",
  "version": "1.0.0",
  "description": "Modernized website for Engler GmbH using Tailwind CSS v4",
  "main": "main.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./input.css -o ./style.css",
    "watch:css": "npx @tailwindcss/cli -i ./input.css -o ./style.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"npx serve -p 3000 .\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1"
  }
}
